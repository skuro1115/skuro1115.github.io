# PayPal Smart Buttons (フロント側に露出可能な公開クライアントID)
# https://developer.paypal.com/dashboard/applications/sandbox or /live
VITE_PAYPAL_CLIENT_ID=

# 寄付 API (skuro-api / Vercel Functions) のベース URL
# 例: https://skuro-api.vercel.app  /  ローカル開発時は http://localhost:3000
# 未設定 or 空のときは /donate ページがモック決済モードで動作する
VITE_DONATE_API_BASE=
